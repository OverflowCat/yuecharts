{
  "width": 700,
  "height": 500,
  "title": {
    "text": "Bar Chart with Axis Breaks",
    "subtext": "Click the break area to expand it",
    "left": "center",
    "textStyle": { "fontSize": 20 },
    "subtextStyle": { "color": "#175ce5", "fontSize": 15, "fontWeight": "bold" }
  },
  "tooltip": {
    "trigger": "axis",
    "axisPointer": { "type": "shadow" }
  },
  "legend": {},
  "grid": { "top": 120 },
