import {
  "OverflowCat/yuecharts" @lib,
}

options(
  link: {
    "wasm": {
      "export-memory-name": "memory",
      "exports": [ "do_render", "version" ],
    },
    "wasm-gc": {
      "exports": [ "render", "version" ],
      "use-js-builtin-string": true,
    },
  },
  targets: { "main_gc.mbt": [ "wasm-gc" ], "main_linear.mbt": [ "wasm" ] },
)
